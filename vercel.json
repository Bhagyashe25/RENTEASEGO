{
  "version": 2,
  "builds": [
    {
      "src": "server/Server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["frontend/dist/**"]
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "server/Server.js" },
    { "src": "/(.*)", "dest": "server/Server.js" }
  ]
}